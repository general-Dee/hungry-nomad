# hungry-nomad environment variables
# Copy this file to .env.local and fill in real values — .env.local is gitignored.
# "Safe to duplicate" / "must stay exclusive" classification is per
# docs/PLATFORM-CONTRACT.md §5 (Environment / Secrets Boundary) — see that doc
# for the full reasoning behind each var.

# --- Supabase (public, safe to duplicate — see docs/PLATFORM-CONTRACT.md §5) ---
# Identifies the shared Supabase project + public anon access; no elevated
# privilege, so a second app can reuse these as-is.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase service role (server-only — must stay exclusive to this app) ---
# Server-only secret used exclusively by src/lib/supabaseAdmin.ts for all
# orders/order_items reads and writes in the app's API routes; bypasses Row
# Level Security. Must NEVER be prefixed with NEXT_PUBLIC_ and must never be
# referenced from a 'use client' component or any code shipped to the
# browser bundle. Obtain it from the Supabase Dashboard -> Settings -> API ->
# service_role secret key. A second app needing elevated access must
# provision its own (see PLATFORM-CONTRACT.md §5) — do not reuse this one.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Paystack ---
# Server-only secret, used in src/app/api/verify-payment/route.ts to call
# Paystack's verify endpoint — must stay exclusive to this app.
PAYSTACK_SECRET_KEY=sk_test_xxx
# Public key used client-side to open the Paystack widget (src/app/checkout/page.tsx).
# Technically public, but there's no reason another app (e.g. a staff dashboard)
# would need to initiate customer payments — treat as not-applicable elsewhere.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# --- Resend / email (must stay exclusive to this app) ---
# This app's own email-sending config (src/lib/email.ts). A second app sending
# its own notifications should provision its own Resend key/from-address.
RESEND_API_KEY=re_xxx
ORDER_EMAIL_FROM=onboarding@resend.dev
STAFF_EMAIL=staff@example.com

# --- Upstash Redis rate limiting (must stay exclusive to this app) ---
# Optional — rate limiting is silently skipped if unset (src/lib/ratelimit.ts).
# A second app needing its own rate limiting should provision its own Redis
# instance rather than sharing this app's keyspace/prefixes
# (ratelimit:orders:create, ratelimit:orders:track).
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- Sentry (must stay exclusive to this app) ---
# This app's own error-tracking project. A second app should have its own
# Sentry project/DSN so errors from the two apps aren't mixed together.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Used at build time (next.config.js) by the Sentry webpack plugin.
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
# Read automatically by the Sentry build plugin (not referenced explicitly in
# code). Without it, source map upload is skipped — errors still report, just
# with unminified stack traces.
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# --- Analytics / tracking IDs (public, safe to duplicate) ---
# Public tracking IDs — safe to reuse if a second app wants shared analytics,
# otherwise skip.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=your-meta-pixel-id

# --- Site URL (public, safe to duplicate) ---
# Used in src/lib/site.ts; falls back to https://yourdomain.com if unset.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# --- Staff API (server-only, must stay exclusive to this app) ---
# Shared secret checked against the x-staff-secret header by the
# PATCH /api/orders/[id] status-transition endpoint
# (src/app/api/orders/[id]/route.ts). Provisional stopgap, not real auth —
# see docs/PLATFORM-CONTRACT.md §4. The endpoint fails closed with 503 if
# this is unset.
STAFF_API_SECRET=your-staff-api-secret
